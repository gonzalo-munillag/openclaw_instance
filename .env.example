# --- OpenClaw Docker Configuration ---

# Docker image (change to your DockerHub image for RPi deployment)
# e.g. OPENCLAW_IMAGE=yourdockerhubuser/openclaw:latest
OPENCLAW_IMAGE=openclaw:local

# Gateway auth token (generate with: openssl rand -hex 32)
OPENCLAW_GATEWAY_TOKEN=

# Host paths for persistent state
OPENCLAW_CONFIG_DIR=~/.openclaw
OPENCLAW_WORKSPACE_DIR=~/.openclaw/workspace

# Gateway networking
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
